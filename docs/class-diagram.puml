@startuml class-diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam classBackgroundColor #d9ead3
skinparam classBorderColor #6aa84f
skinparam packageBackgroundColor #f0f9f0
skinparam packageBorderColor #6aa84f
skinparam ArrowColor #333333
skinparam linetype ortho

' ── Application ──────────────────────────────────────────────────────
package "Massage Reservation" {

    class MassageReservation <<Application>> {
    }
}

' ── Auth Resources ────────────────────────────────────────────────────
class Auth <<Resource>> {
    <<POST>> + register() : User
    <<POST>> + login() : User
    <<GET>>  + logout() : void
}

' ── Shop Resources ────────────────────────────────────────────────────
class Shops <<Resource>> {
    <<GET>>  + getShops() : Shop[]
    <<POST>> + createShop() : Shop
}

class Shop <<Resource>> {
    <<GET>>    + getShop() : Shop
    <<PUT>>    + updateShop() : Shop
    <<DELETE>> + deleteShop() : void
}

' ── Service Resources ─────────────────────────────────────────────────
class Services <<Resource>> {
    <<GET>>  + getServices() : Service[]
    <<POST>> + createService() : Service
}

class Service <<Resource>> {
    <<GET>>    + getService() : Service
    <<PUT>>    + updateService() : Service
    <<DELETE>> + deleteService() : void
}

' ── Reservation Resources ─────────────────────────────────────────────
class Reservations <<Resource>> {
    <<GET>>  + getReservations() : Reservation[]
    <<POST>> + addReservation() : Reservation
}

class Reservation <<Resource>> {
    <<PUT>>    + updateReservation() : Reservation
    <<DELETE>> + deleteReservation() : void
}

' ── User Resources ────────────────────────────────────────────────────
class UserTier <<Resource>> {
    <<PUT>> + updateUserTier() : User
}

' ── Representations ───────────────────────────────────────────────────
class ShopRepr <<Representation>> {
    - name : String
    - address : String
    - phone : String
    - open_time : String
    - close_time : String
}

class ServiceRepr <<Representation>> {
    - shop : ObjectId
    - name : String
    - price : Number
    - duration : Number
    - description : String
    - tier : String
}

class ReservationRepr <<Representation>> {
    - user : ObjectId
    - service : ObjectId
    - appointment_date : String
    - appointment_time : String
    - status : String
}

class UserRepr <<Representation>> {
    - name : String
    - email : String
    - phone : String
    - password : String
    - role : String
    - tier : String
}

' ── Path connections (Application → Resources) ────────────────────────
MassageReservation ..> Auth       : /auth\n<<Path>>
MassageReservation ..> Shops      : /shops\n<<Path>>
MassageReservation ..> Services   : /services\n<<Path>>
MassageReservation ..> Reservations : /reservations\n<<Path>>
MassageReservation ..> UserTier   : /users/{id}/tier\n<<Path>>

' ── Path connections (Collection → Individual) ────────────────────────
Shops ..> Shop              : /{shopId}\n<<Path>>
Services ..> Service        : /{serviceId}\n<<Path>>
Reservations ..> Reservation : /{reservationId}\n<<Path>>

' ── use: Resource → Representation ───────────────────────────────────
Shops       ..> ShopRepr        : <<use>>
Shop        ..> ShopRepr        : <<use>>
Services    ..> ServiceRepr     : <<use>>
Service     ..> ServiceRepr     : <<use>>
Reservations ..> ReservationRepr : <<use>>
Reservation  ..> ReservationRepr : <<use>>
Auth        ..> UserRepr        : <<use>>
UserTier    ..> UserRepr        : <<use>>

' ── Representation inheritance ────────────────────────────────────────
ShopRepr    <|-- ServiceRepr  : shop ref
UserRepr    <|-- ReservationRepr : user ref

@enduml
